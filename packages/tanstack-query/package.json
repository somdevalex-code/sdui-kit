{
  "name": "@sdui-kit/tanstack-query",
  "version": "0.1.0",
  "description": "TanStack Query adapter helpers for SDUI Kit.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sdui-kit/core": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/query-core": ">=5"
  },
  "peerDependenciesMeta": {
    "@tanstack/query-core": {
      "optional": true
    }
  }
}
