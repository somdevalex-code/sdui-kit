{
  "name": "@sdui-kit/core",
  "version": "0.1.1",
  "description": "Framework-agnostic SDUI runtime core.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somdevalex-code/sdui-kit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/somdevalex-code/sdui-kit/issues"
  },
  "homepage": "https://github.com/somdevalex-code/sdui-kit/tree/main/packages/core#readme",
  "keywords": ["sdui", "server-driven-ui", "typescript", "runtime"],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
