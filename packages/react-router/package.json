{
  "name": "@sdui-kit/react-router",
  "version": "0.1.0",
  "description": "React Router navigation adapter for SDUI Kit.",
  "license": "MIT",
  "keywords": ["sdui", "server-driven-ui", "react-router", "typescript"],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sdui-kit/core": "workspace:*"
  },
  "peerDependencies": {
    "react-router-dom": ">=6"
  },
  "peerDependenciesMeta": {
    "react-router-dom": {
      "optional": true
    }
  }
}
