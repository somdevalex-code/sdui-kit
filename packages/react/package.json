{
  "name": "@sdui-kit/react",
  "version": "0.1.1",
  "description": "React adapter for SDUI Kit.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somdevalex-code/sdui-kit.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/somdevalex-code/sdui-kit/issues"
  },
  "homepage": "https://github.com/somdevalex-code/sdui-kit/tree/main/packages/react#readme",
  "keywords": ["sdui", "server-driven-ui", "react", "typescript"],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sdui-kit/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
