{
  "name": "sdui-kit-workspace",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somdevalex-code/sdui-kit.git"
  },
  "bugs": {
    "url": "https://github.com/somdevalex-code/sdui-kit/issues"
  },
  "homepage": "https://somdevalex-code.github.io/sdui-kit/",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "typecheck": "pnpm build && pnpm -r --filter './packages/**' typecheck",
    "test": "pnpm build && pnpm -r --filter './packages/**' test",
    "coverage": "pnpm build && pnpm -r --filter './packages/**' exec vitest run --coverage",
    "smoke:packages": "node scripts/smoke-packages.mjs",
    "release:check": "pnpm typecheck && pnpm test && pnpm --filter @sdui-kit/docs build && pnpm --filter @sdui-kit/react-basic typecheck && pnpm --filter @sdui-kit/react-basic build && pnpm smoke:packages",
    "release:publish": "node scripts/publish-packages.mjs",
    "release:publish:dry-run": "node scripts/publish-packages.mjs --dry-run",
    "docs:dev": "pnpm --filter @sdui-kit/docs dev",
    "example:react": "pnpm --filter @sdui-kit/react-basic dev"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "2.1.9",
    "@vue/server-renderer": "^3.5.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitepress": "^1.6.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
